rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidPlaybook(data) {
      return data.keys().hasAll(['venue', 'strategy', 'createdAt']) &&
             data.keys().size() >= 3 &&
             data.venue is string && data.venue.size() <= 200 &&
             data.strategy is string && data.strategy.size() <= 10000 &&
             data.createdAt == request.time;
    }

    function isValidChallenge(data) {
      return data.keys().hasAll(['creatorId', 'creatorName', 'creatorSquad', 'status', 'createdAt']) &&
             data.creatorId == request.auth.uid &&
             data.creatorName is string && data.creatorName.size() <= 100 &&
             data.creatorSquad is list &&
             data.status in ['pending', 'active', 'completed'] &&
             data.createdAt == request.time;
    }

    // Collections
    match /match_playbooks/{playbookId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(playbookId) && isValidPlaybook(incoming());
    }

    match /challenges/{challengeId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(challengeId) && isValidChallenge(incoming());
      allow update: if isSignedIn() && (
        // Participant update
        (incoming().creatorId == existing().creatorId) &&
        (
          // Opponent Join
          (existing().status == 'pending' && incoming().status == 'active' && 
           incoming().opponentId == request.auth.uid && 
           incoming().diff(existing()).affectedKeys().hasOnly(['opponentId', 'opponentName', 'opponentSquad', 'status'])) ||
          
          // Complete Match (Simulated for now, let's allow participants to update status)
          (existing().status == 'active' && incoming().status == 'completed' &&
           (request.auth.uid == existing().creatorId || request.auth.uid == existing().opponentId) &&
           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'winnerId'])) ||

          // Penalty Share
          (existing().status == 'completed' && incoming().penaltyShared == true &&
           (request.auth.uid == existing().creatorId || request.auth.uid == existing().opponentId) &&
           incoming().diff(existing()).affectedKeys().hasOnly(['penaltyShared']))
        )
      );
    }
  }
}
