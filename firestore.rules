rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /match_playbooks/{playbookId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(playbookId);
      allow update, delete: if false;
    }

    match /challenges/{challengeId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(challengeId);
      allow update: if isSignedIn(); // Allow participants to update status, squads, etc.
      allow delete: if false;
    }
  }
}
